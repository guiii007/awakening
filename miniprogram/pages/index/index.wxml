<view class="container tabbar-page {{theme === 'dark' ? 'dark' : ''}}">
  <!-- 顶部问候 -->
  <view class="mt-6">
    <text class="text-sm text-ink-400">{{greeting}}，欢迎回来</text>
    <view class="mt-2">
      <text class="font-serif text-4xl font-bold text-ink-600 leading-snug">此刻的你，\n愿意为长期的自己停下吗？</text>
    </view>
    <view class="mt-5 card p-5">
      <view class="flex items-start gap-3">
        <text class="text-gold-400" style="font-size: 40rpx; line-height: 1;">✨</text>
        <text class="text-sm text-ink-500 leading-relaxed font-serif italic">"每一次觉察，都是对自己温柔的提醒。"</text>
      </view>
    </view>
  </view>

  <!-- 状态总览 -->
  <view class="mt-8 space-y-4">
    <!-- 连续觉察 -->
    <view class="card p-6">
      <view class="flex items-center gap-5">
        <view class="relative w-28 h-28 flex items-center justify-center">
          <view class="absolute inset-0 rounded-full" style="border: 6rpx solid #E2D9C6;"></view>
          <view class="text-center">
            <text class="font-serif text-3xl font-bold text-ink-600">{{progress.currentStreak}}</text>
            <text class="text-xs text-ink-400 block">觉察天数</text>
          </view>
        </view>
        <view class="flex-1">
          <text class="text-xs tracking-widest text-dawn-400 font-medium uppercase">连续觉察</text>
          <text class="font-serif text-xl font-bold text-ink-600 mt-1 block">每天都在停下来</text>
          <text class="text-xs text-ink-400 mt-2 block">每一次停下来看看自己，都是一种练习</text>
        </view>
      </view>
    </view>

    <!-- 今日克制 -->
    <view class="card p-6">
      <text class="text-xs tracking-widest text-sage-400 font-medium uppercase">今日克制</text>
      <text class="font-serif text-5xl font-bold text-ink-600 mt-2 block">{{todayRestrain}}</text>
      <text class="text-xs text-ink-400 mt-2 block">每一次停下，都是一次胜利</text>
      <view class="mt-4 flex gap-2">
        <view class="chip bg-sage-100 text-sage-500">克制 {{stats.totalRestrain}}</view>
        <view class="chip bg-dawn-100 text-dawn-400">放纵 {{stats.totalRelapse}}</view>
      </view>
    </view>

    <!-- 觉察比例 -->
    <view class="card p-6">
      <text class="text-xs tracking-widest text-dusk-300 font-medium uppercase">觉察比例</text>
      <view class="mt-2">
        <text class="font-serif text-5xl font-bold text-ink-600">{{stats.successRate}}</text>
        <text class="text-2xl text-ink-400">%</text>
      </view>
      <text class="text-xs text-ink-400 mt-2 block">每一次觉察都在积累</text>
      <view class="mt-4 h-3 rounded-full bg-cream-200 overflow-hidden">
        <view class="h-full bg-gradient-to-r from-sage-300 to-dusk-300" style="width: {{stats.successRate}}%;"></view>
      </view>
    </view>
  </view>

  <!-- 快捷救援入口 -->
  <view class="mt-10 card p-8 text-center relative overflow-hidden">
    <text class="text-xs tracking-[0.3em] text-dawn-400 font-medium uppercase">冲动上头时</text>
    <text class="font-serif text-3xl font-bold text-ink-600 mt-3 block">别跟着本能跑，先按下这个按钮</text>
    <text class="text-ink-400 mt-3 text-sm leading-relaxed block">60 秒冷却呼吸 · AI 即时疏导 · 历史经历复盘，三步把你拉回理智</text>
    <view class="mt-7">
      <button bindtap="goToRescue" class="w-40 h-40 mx-auto rounded-full bg-gradient-to-br from-dawn-300 to-dawn-400 text-cream-50 shadow-glow flex flex-col items-center justify-center gap-2 relative overflow-hidden border-0">
        <view class="absolute inset-0 rounded-full bg-dawn-300/50 animate-breath"></view>
        <view class="relative z-10 flex flex-col items-center gap-2">
          <text style="font-size: 72rpx;">🆘</text>
          <text class="font-serif font-bold text-lg text-white">我快失控了</text>
          <text class="text-[22rpx] text-white/80">点这里</text>
        </view>
      </button>
    </view>
  </view>

  <!-- 日签 -->
  <view class="mt-8">
    <view class="card p-6">
      <text class="font-serif text-lg font-bold text-ink-600 mb-4 block">今日日签</text>
      <button bindtap="openQuote" class="w-full flex items-center justify-center gap-3 p-5 rounded-2xl border border-dawn-200/30 transition bg-gradient-to-r from-dawn-100/60 to-sage-100/60">
        <view class="w-12 h-12 rounded-full bg-dawn-200 flex items-center justify-center">
          <text style="font-size: 48rpx;">✨</text>
        </view>
        <view class="text-left flex-1">
          <text class="font-serif font-bold text-ink-600 block">抽取一张日签</text>
          <text class="text-xs text-ink-400 mt-1 block">随机获得一张图片和一段温暖的话</text>
        </view>
      </button>
    </view>

    <!-- 最近的权衡 -->
    <view class="card p-6 mt-4">
      <view class="flex items-center justify-between mb-4">
        <text class="font-serif text-lg font-bold text-ink-600">最近的权衡</text>
        <text wx:if="{{recentTradeoff}}" bindtap="goToTradeoff" class="text-xs text-dawn-400">查看全部</text>
      </view>
      <block wx:if="{{recentTradeoff}}">
        <view bindtap="goToTradeoff" class="w-full text-left p-4 rounded-2xl border border-cream-200/60 transition bg-gradient-to-br from-cream-100/80 to-dawn-100/30">
          <text class="text-[11px] tracking-widest text-dawn-400 uppercase font-medium mb-1.5 block">长期目标</text>
          <text class="font-serif text-base font-bold text-ink-600 leading-snug line-clamp-2 block">{{recentTradeoff.longGoal}}</text>
          <view class="mt-3 flex items-start gap-2">
            <view class="chip bg-dawn-100/70 text-dawn-400 text-[11px] py-1">舍：{{recentTradeoff.sacrifices[0] || '—'}}</view>
          </view>
          <text class="mt-3 text-xs text-ink-400 italic block">「{{recentTradeoff.longReward}}」</text>
        </view>
      </block>
      <block wx:else>
        <view class="text-center py-8">
          <text style="font-size: 64rpx; opacity: 0.3;">⚖️</text>
          <text class="text-sm text-ink-400 mt-2 block">还没有权衡笔记</text>
          <button bindtap="goToTradeoff" class="btn-ghost mt-4 text-sm">写第一份</button>
        </view>
      </block>
    </view>
  </view>

  <!-- 最近事件流 -->
  <view wx:if="{{events.length > 0}}" class="mt-8 card p-6">
    <view class="flex items-center justify-between mb-4">
      <text class="font-serif text-lg font-bold text-ink-600">最近的事件</text>
      <text bindtap="goToStats" class="text-xs text-dawn-400">成长面板</text>
    </view>
    <view class="space-y-2">
      <block wx:for="{{events.slice(-4).reverse()}}" wx:key="id">
        <view class="flex items-center gap-3 p-2.5 rounded-xl">
          <view class="w-2 h-2 rounded-full {{item.type === 'restrain' ? 'bg-sage-300' : 'bg-dawn-300'}}"></view>
          <text class="text-xs text-ink-400 w-16 shrink-0">{{item.timestamp}}</text>
          <text class="text-sm text-ink-600 flex-1 truncate">{{item.scenario || item.trigger}}</text>
          <view class="text-[11px] px-2 py-0.5 rounded-full {{item.type === 'restrain' ? 'bg-sage-100 text-sage-500' : 'bg-dawn-100 text-dawn-400'}}">
            {{item.type === 'restrain' ? '克制' : '放纵'}}
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 日签弹窗 -->
  <view wx:if="{{showQuote}}" class="fixed inset-0 z-50 flex items-center justify-center p-4" style="background: rgba(42, 39, 36, 0.6); backdrop-filter: blur(4px);" bindtap="closeQuote">
    <view class="w-full max-w-lg bg-cream-50 rounded-3xl overflow-hidden shadow-2xl" catchtap="">
      <view class="relative aspect-video bg-cream-100">
        <block wx:if="{{quoteLoading}}">
          <view class="absolute inset-0 flex items-center justify-center">
            <text class="text-dawn-400 animate-spin" style="font-size: 64rpx;">🔄</text>
          </view>
        </block>
        <block wx:else>
          <image wx:if="{{quoteImageUrl}}" src="{{quoteImageUrl}}" mode="aspectFill" class="w-full h-full" />
        </block>
        <view class="absolute top-3 right-3 flex gap-2">
          <view bindtap="refreshQuote" class="w-8 h-8 rounded-full bg-ink-900/30 flex items-center justify-center backdrop-blur-sm">
            <text class="text-white">🔄</text>
          </view>
          <view bindtap="closeQuote" class="w-8 h-8 rounded-full bg-ink-900/30 flex items-center justify-center backdrop-blur-sm">
            <text class="text-white">✕</text>
          </view>
        </view>
      </view>
      <view class="p-6">
        <text class="text-xs tracking-widest text-dawn-400 font-medium uppercase mb-2 block">{{currentQuote.title}}</text>
        <text class="font-serif text-lg text-ink-600 leading-relaxed mb-4 block">{{currentQuote.quote}}</text>
        <text class="text-sm text-ink-400">—— {{currentQuote.author}}</text>
      </view>
    </view>
  </view>
</view>
