/* index page */
.w-full { width: 100%; }
.w-40 { width: 160rpx; }
.w-28 { width: 112rpx; }
.w-12 { width: 48rpx; }
.w-8 { width: 32rpx; }
.w-16 { width: 64rpx; }
.h-40 { height: 160rpx; }
.h-28 { height: 112rpx; }
.h-12 { height: 48rpx; }
.h-8 { height: 32rpx; }
.h-3 { height: 12rpx; }
.max-w-lg { max-width: 600rpx; }
.space-y-4 > * + * { margin-top: 32rpx; }
.space-y-2 > * + * { margin-top: 16rpx; }

.fixed { position: fixed; }
.inset-0 { top: 0; right: 0; bottom: 0; left: 0; }
.z-50 { z-index: 50; }
.relative { position: relative; }
.absolute { position: absolute; }
.top-3 { top: 24rpx; }
.right-3 { right: 24rpx; }

.overflow-hidden { overflow: hidden; }
.aspect-video { aspect-ratio: 16 / 9; }
.block { display: block; }

.border-0 { border-width: 0; }
.bg-ink-900\/30 { background: rgba(42, 39, 36, 0.3); }
.bg-ink-900\/60 { background: rgba(42, 39, 36, 0.6); }
.backdrop-blur-sm { backdrop-filter: blur(8rpx); }
.backdrop-blur-md { backdrop-filter: blur(16rpx); }
.shadow-2xl { box-shadow: 0 25rpx 50rpx -12rpx rgba(58, 54, 51, 0.25); }
.bg-gradient-to-br { background: linear-gradient(to bottom right, var(--from), var(--to)); }
.from-dawn-300 { --from: #E8B4A0; }
.to-dawn-400 { --to: #DD9A82; }
.from-cream-100\/80 { --from: rgba(247, 243, 236, 0.8); }
.to-dawn-100\/30 { --to: rgba(247, 221, 210, 0.3); }
.from-sage-300 { --from: #8FA89B; }
.to-dusk-300 { --to: #9B8FA8; }
.from-dawn-100\/60 { --from: rgba(247, 221, 210, 0.6); }
.to-sage-100\/60 { --to: rgba(221, 229, 224, 0.6); }
.text-cream-50 { color: #FBF8F2; }
.text-white { color: #ffffff; }
.text-white\/80 { color: rgba(255, 255, 255, 0.8); }
.text-gold-400 { color: #D4B896; }
.text-dusk-300 { color: #9B8FA8; }
.bg-sage-100 { background: #DDE5E0; }
.bg-dawn-100 { background: #F7DDD2; }
.bg-cream-100 { background: #F7F3EC; }
.bg-cream-200 { background: #EFE9DD; }
.bg-cream-50 { background: #FBF8F2; }
.bg-dawn-200 { background: #EFC4B4; }
.bg-sage-300 { background: #8FA89B; }
.bg-dawn-300\/50 { background: rgba(232, 180, 160, 0.5); }
.bg-dawn-300\/70 { background: rgba(232, 180, 160, 0.7); }

.z-10 { z-index: 10; }
.tracking-\[0\.3em\] { letter-spacing: 0.3em; }

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.animate-spin {
  animation: spin 1s linear infinite;
}
