.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background:
    radial-gradient(at 12% 8%, rgba(232, 180, 160, 0.18) 0px, transparent 50%),
    radial-gradient(at 88% 12%, rgba(155, 143, 168, 0.14) 0px, transparent 45%),
    linear-gradient(180deg, #FBF8F2 0%, #F7F3EC 100%);
}

.dark.chat-page {
  background:
    radial-gradient(at 12% 8%, rgba(232, 180, 160, 0.08) 0px, transparent 50%),
    radial-gradient(at 88% 12%, rgba(155, 143, 168, 0.06) 0px, transparent 45%),
    linear-gradient(180deg, #1F1D1B 0%, #151413 100%);
}

.chat-header {
  padding-top: calc(env(safe-area-inset-top) + 20rpx);
  background: rgba(251, 248, 242, 0.9);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(239, 233, 221, 0.6);
  position: sticky;
  top: 0;
  z-index: 10;
}

.dark .chat-header {
  background: rgba(26, 24, 23, 0.9);
  border-bottom-color: rgba(42, 39, 36, 0.3);
}

.chat-messages {
  flex: 1;
  width: 100%;
}

.chat-input {
  background: rgba(251, 248, 242, 0.95);
  border-top: 1rpx solid rgba(239, 233, 221, 0.6);
  padding-bottom: env(safe-area-inset-bottom);
}

.dark .chat-input {
  background: rgba(26, 24, 23, 0.95);
  border-top-color: rgba(42, 39, 36, 0.3);
}

.space-y-4 > * + * {
  margin-top: 32rpx;
}

.w-9 { width: 36rpx; }
.h-9 { height: 36rpx; }
.w-8 { width: 32rpx; }
.h-8 { height: 32rpx; }
.w-12 { width: 48rpx; }
.h-12 { height: 48rpx; }
.max-h-32 { max-height: 256rpx; }
.max-w-\[75\%\] { max-width: 75%; }

.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.py-3 { padding-top: 24rpx; padding-bottom: 24rpx; }
.p-3 { padding: 24rpx; }
.p-4 { padding: 32rpx; }
.pb-3 { padding-bottom: 24rpx; }

.gap-1\.5 { gap: 12rpx; }
.gap-2 { gap: 16rpx; }
.gap-3 { gap: 24rpx; }

.text-xs { font-size: 24rpx; }
.text-sm { font-size: 26rpx; }
.text-lg { font-size: 32rpx; }

.rounded-full { border-radius: 999rpx; }
.rounded-2xl { border-radius: 32rpx; }
.rounded-tl-sm { border-top-left-radius: 8rpx; }
.rounded-tr-sm { border-top-right-radius: 8rpx; }

.bg-dawn-200 { background: #EFC4B4; }
.bg-sage-200 { background: #BFCDC4; }
.bg-dawn-300 { background: #E8B4A0; }
.bg-cream-50 { background: #FBF8F2; }
.bg-cream-100 { background: #F7F3EC; }
.bg-cream-100\/80 { background: rgba(247, 243, 236, 0.8); }

.text-ink-500 { color: #4A4540; }
.text-ink-600 { color: #3A3633; }
.text-white { color: #ffffff; }

.font-medium { font-weight: 500; }
.font-bold { font-weight: 700; }
.font-serif { font-family: 'Songti SC', 'SimSun', serif; }

.shrink-0 { flex-shrink: 0; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.justify-end { justify-content: flex-end; }
.justify-between { justify-content: space-between; }
.flex { display: flex; }
.flex-col { flex-direction: column; }
.overflow-x-auto { overflow-x: auto; }
.resize-none { resize: none; }

.leading-relaxed { line-height: 1.8; }

.opacity-50 { opacity: 0.5; }

.sticky { position: sticky; }
.top-0 { top: 0; }
.z-10 { z-index: 10; }

.text-left { text-align: left; }
.justify-start { justify-content: flex-start; }
